# ── Required ──────────────────────────────────────────
JELLYFIN_URL=http://192.168.1.100:8096
JELLYFIN_API_KEY=your_jellyfin_api_key_here

# ── Optional: Radarr (movie file details + queue) ─────
RADARR_URL=http://192.168.1.100:7878
RADARR_API_KEY=your_radarr_api_key_here

# ── Optional: Sonarr (TV queue) ───────────────────────
SONARR_URL=http://192.168.1.100:8989
SONARR_API_KEY=your_sonarr_api_key_here

# ── Optional: Seer (ratings, cast, requests) ──
SEER_URL=http://192.168.1.100:5055
SEER_API_KEY=your_seer_api_key_here

# ── Display settings ──────────────────────────────────
POLL_INTERVAL=5        # How often to poll Jellyfin (seconds)
SCREEN_DURATION=15     # How long each screen shows (seconds)
SCREEN_ROTATION=true   # Rotate idle screens when nothing is playing
SCREEN_TRANSITION=cycle # cycle, fade, slide, or wipe
IDLE_SCREENS=upcoming,spotlight,idle # Idle screen order
CLOCK_TIMEZONE=America/Chicago # Optional; falls back to TZ/browser time

# ── Now Playing filters ───────────────────────────────
# Comma-separated Jellyfin user/device names. Whitelists are optional allow-lists.
NOW_PLAYING_USER_WHITELIST=
NOW_PLAYING_USER_BLACKLIST=
NOW_PLAYING_DEVICE_WHITELIST=
NOW_PLAYING_DEVICE_BLACKLIST=
